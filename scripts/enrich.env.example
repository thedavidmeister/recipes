# Copy to .env.enrich (gitignored) and fill in. Sourced by scripts/enrich-cron.sh.
# NEVER commit real values.

# The deployed app's base URL — where the worker pulls work and pushes readings.
RECIPES_API_URL=https://api.recipes.lehlehleh.com

# The machine key that gates the enrich endpoints — the SAME value as the app's
# INGEST_API_KEY (and the repo's INGEST_API_KEY GitHub Actions secret).
INGEST_API_KEY=

# Provenance stamped on every reading: the model that actually did the reading.
# Match it to ENRICH_CLAUDE_MODEL below (e.g. sonnet -> claude-sonnet-5).
ENRICH_MODEL=claude-sonnet-5

# Optional overrides (defaults are in scripts/enrich-cron.sh):
#   ENRICH_CLAUDE_MODEL=sonnet         # the Claude Code session model (alias or full id)
#   ENRICH_MAX_BATCHES=20              # claude sessions per cron run
#   ENRICH_SESSION_TIMEOUT=900         # wall-clock seconds per session
