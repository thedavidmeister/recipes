# Address the backend binds to.
BIND_ADDR=0.0.0.0:8080

# Database. Local dev: a local libSQL file. Prod: the Turso libsql:// URL.
DATABASE_URL=file:recipes.db
# Turso WRITE token — required only for a remote libsql:// URL. Keep secret.
TURSO_AUTH_TOKEN=

# Log filter (tracing EnvFilter syntax).
RUST_LOG=recipe_backend=debug,tower_http=info,info
