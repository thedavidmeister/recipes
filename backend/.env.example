# Address the backend binds to.
BIND_ADDR=0.0.0.0:8080

# Database. Local dev: a local libSQL file. Prod: the Turso libsql:// URL.
DATABASE_URL=file:recipes.db
# Turso WRITE token — required only for a remote libsql:// URL. Keep secret.
TURSO_AUTH_TOKEN=

# Log filter (tracing EnvFilter syntax).
RUST_LOG=recipe_backend=debug,tower_http=info,info

# --- Telegram auth (#25) -----------------------------------------------------
# Auth is MANDATORY: every endpoint requires a session, so the backend refuses to
# start without all three of these. A backend that cannot mint a login can serve
# nothing, and failing at startup beats failing on the first request.

# From @BotFather. A backend secret, handled like TURSO_AUTH_TOKEN — it must
# never reach the browser. Keep out of git.
TELEGRAM_BOT_TOKEN=

# The bot's @name (no @), used to build the t.me deep link.
TELEGRAM_BOT_USERNAME=

# A random secret you choose, registered with setWebhook and echoed back by
# Telegram in X-Telegram-Bot-Api-Secret-Token. NOT optional: the webhook URL is
# public, so without this anyone can POST a forged `/start` claiming any Telegram
# id — i.e. log in as anybody. Generate one:
#   head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n'
TELEGRAM_WEBHOOK_SECRET=

# Point Telegram at the deployed webhook (once, after deploy):
#   curl -X POST "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook" \
#     -d "url=https://<backend-host>/api/telegram/webhook" \
#     -d "secret_token=$TELEGRAM_WEBHOOK_SECRET"
